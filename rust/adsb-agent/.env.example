# Copy to .env and adjust values for your environment.
# All vars use the ADSB_AGENT_ prefix.

# MLflow tracing — start server with: mlflow server --port 5010
ADSB_AGENT_MLFLOW_ENABLED=true
ADSB_AGENT_MLFLOW_TRACKING_URI=http://localhost:5010
ADSB_AGENT_MLFLOW_EXPERIMENT=adsb-agent

# MinIO artifact store — required when MLflow uses S3-compatible storage (MinIO).
# Without these, boto3 tries to reach real AWS S3 and fails with NoCredentialsError.
# Match these values to your docker-compose MinIO service credentials.
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=us-east-1

# LLM endpoint (LM Studio, Ollama, OpenAI, etc.)
ADSB_AGENT_LLM_BASE_URL=http://localhost:1234/v1
ADSB_AGENT_LLM_API_KEY=lm-studio
# A capable tool-calling model is REQUIRED for the multi-hop ReAct loop. The old
# 1.2B model cannot plan/chain tool calls. Pull e.g. Qwen2.5-7B-Instruct (or 14B
# if you have the RAM) in LM Studio/Ollama. Use the small model only on
# resource-constrained devices, expecting weak reasoning.
ADSB_AGENT_MODEL=qwen2.5-7b-instruct
#ADSB_AGENT_MODEL=qwen2.5-14b-instruct
#ADSB_AGENT_MODEL=liquidai/lfm2.5-1.2b-instruct-mlx  # tiny fallback, weak reasoning

# Tauri tool server (read-only DuckDB data plane the agent chains internally).
# Must match the desktop app's ADSB_AGENT_TOOL_SERVER_PORT (default 8787).
ADSB_AGENT_TOOL_SERVER_URL=http://127.0.0.1:8787

# Agent server
ADSB_AGENT_PORT=8000
ADSB_AGENT_HOST=0.0.0.0

# Telemetry and tracking opt-out (for MLflow and any other tools respecting these vars)
MLFLOW_DISABLE_TELEMETRY=true
DO_NOT_TRACK=true