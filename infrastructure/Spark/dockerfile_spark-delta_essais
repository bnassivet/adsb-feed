# PySpark + Delta Lake on Apache Spark 4.1
#
# Canonical example for running a PySpark/Delta application on Spark 4.1.
# Spark 4.x is Scala 2.13 only and requires Java 17+. Delta Lake for Spark 4.1
# is delta-spark 4.2.0 (artifact delta-spark_2.13-4.2.0.jar; PyPI delta-spark==4.2.0).
# The old `delta-core` artifact was renamed to `delta-spark`.

# ---------------------------------------------------------------------------
# Dockerfile: PySpark 4.1 + Delta image
# ---------------------------------------------------------------------------
# Base image ships Spark 4.1.1 (Scala 2.13, Java 17). Delta is pulled from PyPI
# so spark-submit can resolve it via configure_spark_with_delta_pip, or the JAR
# can be baked in for offline clusters.
FROM apache/spark:4.1.1

USER root

# Python deps for a Delta-enabled PySpark app (Spark 4 requires pandas >= 2.2).
RUN pip install --no-cache-dir \
    "pyspark==4.1.1" \
    "delta-spark==4.2.0" \
    "pandas>=2.2" \
    "pyarrow>=15.0"

# Optional: bake the Delta JAR in for offline / air-gapped clusters.
# COPY delta-spark_2.13-4.2.0.jar /opt/spark/jars/delta-spark_2.13-4.2.0.jar

USER spark

# ---------------------------------------------------------------------------
# docker-compose: Spark 4.1 standalone cluster (master + 2 workers) with MinIO
# ---------------------------------------------------------------------------
# Save as a separate docker-compose.yml; `image: spark-delta` is the image built
# from the Dockerfile above. MinIO provides S3-compatible storage for Delta tables.
